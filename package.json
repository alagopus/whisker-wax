{
  "name": "whisker-wax",
  "version": "1.3.1",
  "description": "mustache parser, engine, compiler",
  "main": "index.js",
  "repository": "git@github.com:alagopus/whisker-wax.git",
  "author": "Klaus Rennecke <klaus@rennecke.art>",
  "license": "MIT",
  "bin": {
    "wax": "bin/wax"
  },
  "directories": {
    "bin": "./bin",
    "lib": "./lib",
    "test": "./test"
  },
  "files": [
    "bin/wax",
    "lib/*.js"
  ],
  "scripts": {
    "fix": "standard --fix . bin/*",
    "good": "run-s lint test || run-s report",
    "lint": "standard . bin/*",
    "report": "tap --coverage-report=html",
    "test": "tap run test/*.js --show-full-coverage"
  },
  "devDependencies": {
    "npm-run-all": "^4.1.5",
    "standard": "^17.1.2",
    "tap": "^21.7.2"
  },
  "engines": {
    "node": ">=20.20.2"
  }
}
